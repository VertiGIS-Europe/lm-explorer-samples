{
	"compilerOptions": {
		"outDir": "./dist/",
		"noImplicitAny": true,
		"module": "ESNext",
		"target": "es5",
		"jsx": "react",
		"allowJs": true,
		"moduleResolution": "node",
		"strict": true,
		"strictNullChecks": false,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"baseUrl": "./src",
		"paths": {
			"@components/*": ["./components/*"], //Alias für Componenten
			"@models/*": ["./models/*"], //Alias für models
			"@services/*": ["./services/*"], //Alias für Services
			"@utils/*": ["./utils/*"], //Alias für Utils
			"@helper": ["./utils/helper.js"] //Alias für die helper.js
		}
	}
}
